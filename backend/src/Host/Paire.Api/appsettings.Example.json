{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "Supabase": {
    "Url": "https://your-project.supabase.co",
    "Key": "your-supabase-service-role-key-here",
    "Schema": "public"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=aws-0-eu-central-1.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.your-project;Password=your-database-password"
  },
  "Database": {
    "MaxPoolSize": 3,
    "ConnectionIdleLifetimeSeconds": 30
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "your-email@gmail.com",
    "SenderName": "Paire",
    "Username": "your-email@gmail.com",
    "Password": "your-resend-api-key-or-app-password",
    "EnableSsl": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "https://www.thepaire.org",
      "https://thepaire.org"
    ]
  },
  "JwtSettings": {
    "Secret": "your-256-bit-secret-key-must-be-at-least-32-chars-long",
    "Issuer": "Codename_Shield",
    "Audience": "Codename_Shield_Clients",
    "ExpirationInMinutes": 60,
    "RefreshTokenValidityInDays": 7
  },
  "Shield": {
    "BaseUrl": "http://localhost:5002/api/v1/auth"
  },
  "Features": {
    "EnableChatbot": true,
    "EnableEmailReminders": true,
    "EnableAnalytics": true,
    "EnablePartnership": true
  },
  "ReminderSettings": {
    "CheckIntervalMinutes": 60,
    "DefaultBillReminderDays": 3,
    "DefaultLoanReminderDays": 7,
    "DefaultBudgetThreshold": 90
  }
}
